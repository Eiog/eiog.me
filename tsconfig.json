{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends":"@eiog/ts-config/tsconfig.json",
  // "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~/*": [
        "src/*"
      ]
    },
    "types": [
      "@astrojs/image/client",
      "vite-plugin-pwa/info"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
